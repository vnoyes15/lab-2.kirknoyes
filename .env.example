# Arx Phase 1 environment variables (Section 86)
# Copy to .env and fill in. Missing required variables cause explicit startup
# failure, not silent misbehavior (arx/api/config.py enforces this).

# --- Anthropic ---
# Format: sk-ant-... Never log. Never expose in any API response.
ANTHROPIC_API_KEY=

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
# Client-side auth flows only.
SUPABASE_ANON_KEY=
# All server-side DB operations. Bypasses RLS — never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database ---
# postgresql://[user]:[password]@[host]:[port]/[db]
# DATABASE_URL: used only by scripts/migrate.py and scripts/seed_org.py. This
# connection intentionally bypasses RLS (it's how migrations create tables/policies
# and how seed_org.py bootstraps the first org) — a superuser / Supabase service-role
# connection string belongs here.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arx_dev

# APP_DATABASE_URL: what the running API actually queries through (arx/db/connection.py).
# MUST be a role WITHOUT BYPASSRLS/superuser, or RLS silently does nothing (Postgres
# superusers and BYPASSRLS roles ignore every RLS policy, full stop). In production this
# is Supabase's `authenticated` role; locally it's the role arx/db/local_dev/auth_shim.sql
# creates. Falls back to DATABASE_URL if unset — do not rely on that fallback past local
# smoke-testing, since that silently drops back to a bypassing connection.
APP_DATABASE_URL=postgresql://arx:arx@localhost:5432/arx_dev

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Runtime ---
# development | staging | production
ENVIRONMENT=development

# ZONIQ org_id after initial seed. Development only — never set in production.
DEFAULT_ORG_ID=

# --- Model config (Section 05, R4/N6 — model-agnostic architecture) ---
MODEL_NAME=claude-sonnet-4-20250514
MAX_TOKENS_DEFAULT=4096
TOKEN_BUDGET_MONTHLY_DEFAULT=500000

# --- Storage ---
# Create manually in Supabase dashboard before Phase 2.
SUPABASE_STORAGE_BUCKET=arx-documents
